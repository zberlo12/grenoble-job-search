# Job Search System — Profile Environment File
#
# Copy this to .env.<yourname>  (e.g. .env.zack or .env.sarah)
# Then run:  python setup.py --profile <yourname>
#
# NEVER commit the filled-in version — it contains your API token.

# Your Notion integration token
# Get it at: https://www.notion.so/my-integrations → New integration → copy the secret
NOTION_API_TOKEN=secret_your_notion_integration_token_here

# The page ID of your "⚙️ User Profile & Config" page in Notion
# Get it from the page URL: notion.so/.../<PAGE_ID_IS_THE_LAST_PART>
NOTION_CONFIG_PAGE_ID=your_user_profile_page_id_here

# Your base city (used in cover letter date headers, e.g. "Grenoble, le 17 avril 2026")
BASE_CITY=Your City Here

# Your full name (used by make_cv_template.py and make_cl_template.py)
FULL_NAME=Your Full Name Here
