# Secrets — never commit these
.env
.env.*
!.env.template
*.credentials.json
.credentials.json

# MCP config contains API tokens — commit only the template version
.mcp.json

# Active profile state — machine-specific
.active-profile

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Claude — exclude session/cache data but track skill commands
.claude/cache/
.claude/sessions/
.claude/history*

# Application documents — personal/sensitive, not for version control
applications/

# CV/CL templates contain personal content — each user generates their own
templates/*.docx
templates/*.doc

# Generated output files
outputs/*.docx
outputs/*.doc
outputs/*.pdf
